generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MriReport {
  id          String   @id @default(cuid())
  
  // Patient Information
  patientName     String
  patientId       String?
  patientAge      Int?
  patientGender   String?
  referringDoctor String?
  studyDate       DateTime?
  accessionNumber String?
  
  // Study Details
  bodyRegion      String
  studyType       String
  modality        String    @default("MRI")
  scannerModel    String?
  fieldStrength   String?
  
  // Clinical Information
  clinicalIndication String?
  clinicalHistory    String?
  
  // Report Content
  technique      String?
  comparison     String?
  findings       String
  impression     String
  
  // Additional Details
  contrastAdministered Boolean  @default(false)
  contrastAgent       String?
  contrastVolume      String?
  contrastRoute       String?
  
  // Metadata
  reportStatus  String   @default("Draft")
  priority      String   @default("Routine")
  reportNumber  String?
  
  // File attachment
  attachmentPath String?
  attachmentName String?
  fileSize       Int?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([patientName])
  @@index([bodyRegion])
  @@index([studyDate])
  @@index([reportStatus])
  @@index([accessionNumber])
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  bodyRegion  String
  description String?
  technique   String?
  findings    String?
  impression  String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FindingTemplate {
  id          String   @id @default(cuid())
  bodyRegion  String
  label       String
  text        String
  isAbnormal  Boolean  @default(false)
  sortOrder   Int      @default(0)
  isDefault   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([bodyRegion])
}

model HospitalSettings {
  id              String   @id @default(cuid())
  hospitalName    String   @default("MRI Report Center")
  tagline         String?
  address         String?
  phone           String?
  website         String?
  email           String?
  logoUrl         String?
  radiologistName String?
  radiologistQualification String?
  radiologistRegNumber String?
  accreditation   String?
  accreditationNumber  String?
  footerMessage   String   @default("Thank you for choosing our services.")
  reportHeaderColor String @default("#1e3a5f")

  // Print layout options
  reportLayout    String   @default("classic")
  showTechnique   Boolean  @default(true)
  showComparison  Boolean  @default(true)
  showClinicalInfo Boolean  @default(true)
  showSignature   Boolean  @default(true)
  showFooterMessage Boolean  @default(true)
  showAccreditation Boolean  @default(true)
  patientColumns  String   @default("3")
  impressionStyle  String   @default("bordered")
  headerStyle     String   @default("full")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}