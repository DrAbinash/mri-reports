# ===== MRI Report Manager - Environment Variables =====
# Copy this file to .env and adjust values for your setup.

# ----- App -----
NODE_ENV=production
APP_PORT=3080

# ----- Database (SQLite) -----
# In Docker, this is the path INSIDE the container.
# Do NOT change unless you know what you're doing.
DATABASE_URL=file:/app/data/db/mri_reports.db

# ----- File Uploads -----
# Directory inside the container where uploaded files are stored.
# The docker-compose volume maps this to ./data/uploads on your host.
UPLOAD_DIR=/app/data/uploads